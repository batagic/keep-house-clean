{
  "project": "keep-house-clean",
  "name": "Kho Thóc Gia Đình",
  "updated": "2026-06-14",
  "structure_version": "2.1",
  "repo_layout": {
    "code": "Frontend HTML, kho-thoc-api",
    "docs": "BRD, technical, db/migrate, ui/ux",
    "tests": "Script test tự động (domain, coverage)",
    "ops": "Deploy VPS, Nginx, SSH setup"
  },
  "architecture": {
    "frontend": {
      "host": "GitHub Pages",
      "path": "/keep-house-clean/code/",
      "entry": "code/nhat-ky.html",
      "root_redirects": "index.html, nhat-ky.html, … tại repo root → code/"
    },
    "api": {
      "host": "VPS Docker",
      "url": "https://apinhatkyvumua.taho.cat/kho-thoc/",
      "path": "code/kho-thoc-api"
    },
    "database": {
      "engine": "PostgreSQL",
      "name": "kho_thoc",
      "migrations_run": "code/kho-thoc-api/migrations/",
      "migrations_docs": "docs/db/migrate/"
    }
  },
  "deploy": {
    "script": "./ops/vps/deploy.sh --all",
    "ssh_setup": "./ops/vps/setup-ssh.sh",
    "vps_root": "/opt/nhatkyvumua"
  },
  "tests": {
    "domain_nhatky": "bash tests/domain/nhatky/nhatky.sh",
    "coverage": "bash tests/coverage.sh"
  },
  "key_docs": {
    "guide": "docs/project-guide.html",
    "brd": "docs/brd/brd.md",
    "hld": "docs/technical/hld.html",
    "operator": "docs/technical/operator.md"
  },
  "features_shipped": [
    "Nhật ký nhiệm vụ + Gạo/EXP",
    "Đăng ký/xóa bé (max 3/family)",
    "Cách ly gia đình (family_id)",
    "Phiên gia đình — unlock_family (Phase 3.1)",
    "Đổi quà + passcode",
    "Admin JWT",
    "Deploy một lệnh VPS"
  ],
  "workflow_ai": {
    "after_feature": "Hỏi user trước khi git push + deploy",
    "update_docs": ["docs/brd/", "tests/test-case.md"],
    "run_tests": "tests/domain/nhatky/nhatky.sh"
  }
}
