# /opt/nhatkyvumua/kho-thoc-api/.env — copy từ file này trên VPS

PORT=3001
BASE_PATH=/kho-thoc

# Postgres trong container eedt-postgres (cùng Docker network)
DATABASE_URL=postgresql://kho_thoc:MAT_KHAU_MANH@eedt-postgres:5432/kho_thoc

# GitHub Pages gọi API — bắt buộc có origin này
CORS_ORIGINS=https://batagic.github.io

# URL công khai sau deploy (dùng trong config.js):
# https://apinhatkyvumua.taho.cat/kho-thoc

# Kiểm tra: docker inspect eedt-postgres --format '{{range $k, $v := .NetworkSettings.Networks}}{{$k}} {{end}}'
EEDT_DOCKER_NETWORK=docker_eedt-net

# Nếu Nginx Docker khác network — thêm tên network (thường trùng EEDT_DOCKER_NETWORK)
# NGINX_DOCKER_NETWORK=docker_eedt-net
