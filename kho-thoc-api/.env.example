# Copy thành .env — không commit file .env
#
# Hostname trong DATABASE_URL phụ thuộc cách chạy API:
#   - API trong Docker (docker compose):  eedt-postgres
#   - API trên máy host (npm run dev):    localhost

PORT=3001

# Local dev: để trống. VPS production: /kho-thoc
BASE_PATH=

# --- Chọn MỘT dòng phù hợp (bỏ comment dòng còn lại) ---

# API trong Docker (cùng network với eedt-postgres)
DATABASE_URL=postgresql://kho_thoc:CHANGE_ME@eedt-postgres:5432/kho_thoc

# API chạy trực tiếp trên máy (eedt-postgres map 0.0.0.0:5432)
# DATABASE_URL=postgresql://kho_thoc:CHANGE_ME@localhost:5432/kho_thoc

CORS_ORIGINS=https://batagic.github.io,http://localhost:5500,http://127.0.0.1:5500

# Docker network của eedt-postgres (docker inspect eedt-postgres để xem)
# Local thường: docker_eedt-net | VPS có thể: eedt_default
EEDT_DOCKER_NETWORK=docker_eedt-net
